module Mindee
  module V2
    module Product
      module Crop
        module Params
          class CropParameters
            def self.slug: -> String

            def self.from_hash: (params: Hash[String | Symbol, untyped]) -> CropParameters

            def initialize: (
                String,
                ?file_alias: String?,
                ?webhook_ids: Array[String]?,
                ?polling_options: Hash[Symbol | String, untyped] | Input::PollingOptions?,
                ?close_file: bool?
              ) -> void
          end
        end
      end
    end
  end
end
