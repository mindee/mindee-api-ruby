# lib/mindee/v1/parsing/standard/amount_field.rb
module Mindee
  module V1
    module Parsing
      module Standard
        class AmountField < BaseField
          attr_reader value: Float?

          def initialize: (Hash[String | Symbol, untyped], Integer?, ?reconstructed: bool) -> void

          def to_s: -> String
        end
      end
    end
  end
end
